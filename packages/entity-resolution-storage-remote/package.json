{
  "name": "@agentix-e/entity-resolution-storage-remote",
  "version": "0.0.0",
  "description": "Remote storage backend for entity-resolution using PostgreSQL with mTLS support",
  "license": "MIT", 
  "author": "Lambertyan",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo coverage"
  },
  "peerDependencies": {
    "@agentix-e/entity-resolution-core": "workspace:*"
  },
  "devDependencies": {
    "@agentix-e/entity-resolution-core": "workspace:*",
    "eslint": "^9.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
