{
  "name": "@agentix-e/entity-resolver-cli",
  "version": "0.0.0",
  "description": "entity-resolver-cli \u2014 Entity Resolver sub-package",
  "license": "MIT",
  "author": "Lambertyan",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "entity-resolver": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo coverage"
  },
  "dependencies": {
    "@agentix-e/entity-resolver-core": "workspace:*",
    "@agentix-e/entity-resolver-visual": "workspace:*"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.7.0"
  }
}