{
  "name": "@agentix-e/entity-resolver-core",
  "version": "0.0.0",
  "description": "entity-resolver-core \u2014 Entity Resolution sub-package",
  "license": "MIT",
  "author": "Lambertyan",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -r src/matching/scorers/wasm/scorers dist/matching/scorers/wasm/ 2>/dev/null; true",
    "test": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo coverage"
  },
  "dependencies": {
    "apache-arrow": "^21.2.0",
    "murmurhash3js": "^3.0.1",
    "strsimkit": "^0.1.0",
    "union-find": "^1.0.2",
    "wink-nlp": "^2.4.0"
  },
  "devDependencies": {
    "@types/murmurhash3js": "^3.0.7",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.9.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}